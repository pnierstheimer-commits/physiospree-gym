# Physiospree Gym — Beispiel-Umgebungsvariablen
# Kopiere diese Datei nach .env(.local) und fülle die Werte.
# .env* ist in .gitignore (außer dieser .env.example).

# --- Client (im Browser-Bundle sichtbar, NUR öffentliche Keys!) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Server-only (Vercel Functions, NIE im Client) ---
# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...
# Optionales Modell-Override für die /api-Routes
ANTHROPIC_MODEL=claude-sonnet-4-6

# Supabase Service Role (nur serverseitig, umgeht RLS — vertraulich!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

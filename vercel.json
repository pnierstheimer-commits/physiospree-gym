{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/claude-plan.ts": { "includeFiles": "api/prompt/**" },
    "api/claude-coach.ts": { "includeFiles": "api/prompt/**" },
    "api/claude-chat.ts": { "includeFiles": "api/prompt/**" }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/" }
  ]
}
